{{ file_managed_by_ansible }}

[lockdown_audit_details]
{% if run_audit %}
# Audit run
audit_run_date = {{ '%Y-%m-%d - %H:%M:%S' | ansible.builtin.strftime }}
audit_file_local_location = {{ audit_log_dir }}
{% if not audit_only and (post_audit_results is defined and pre_audit_results is defined) %}
audit_summary = {{ (post_audit_results | default(pre_audit_results)) }}
{% endif %}
{% if fetch_audit_output %}
audit_files_centralized_location = {{ audit_output_destination }}
{% endif %}
{% endif %}
